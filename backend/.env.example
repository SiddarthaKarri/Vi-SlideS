# Environment Variables for Vi-SlideS Backend Configuration

# API Port Configuration
PORT=5000

# Database Configuration (Direct URL if using local)
MONGO_URI=mongodb://localhost:27017/vislides

# Security JWT Key (Change in production)
JWT_SECRET=supersecretjwtkey_change_me_in_prod

# OpenAI API Integration (Used by Member 4's AI script)
# Requires a valid API Key from platform.openai.com
GEMINI_API_KEY=your_gemini_api_key_here
